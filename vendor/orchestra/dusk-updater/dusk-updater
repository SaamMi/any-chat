#!/usr/bin/env php
<?php

require $_composer_autoload_path ?? __DIR__.'/vendor/autoload.php';

$app = new Symfony\Component\Console\Application('Dusk Updater');

$app->setVersion(Composer\InstalledVersions::getPrettyVersion('orchestra/dusk-updater'));

$addCommandMethodName = method_exists($app, 'addCommand') ? 'addCommand' : 'add';

$app->{$addCommandMethodName}(new Orchestra\DuskUpdater\DetectCommand());
$app->{$addCommandMethodName}(new Orchestra\DuskUpdater\UpdateCommand());

$app->run();
